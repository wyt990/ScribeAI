generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password      String
  role          String   @default("user") // user | manager
  isActive      Boolean  @default(true)
  avatarUrl     String?
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transcripts      Transcript[]
  summaries        Summary[]
  drafts           Draft[]
  summarySkills    SummarySkill[]
  summaryTemplates SummaryTemplate[]
  auditLogs        AuditLog[]
  operationTraces  OperationTrace[]
  organizations    UserOrganization[]
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  industry    String?
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships UserOrganization[]
}

model UserOrganization {
  userId          String
  organizationId  String
  jobTitle        String?
  responsibilities String?  @db.Text
  isDefault       Boolean  @default(false)

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([userId, organizationId])
  @@index([userId])
}

model SystemSetting {
  key       String   @id
  group     String
  value     String   @db.Text
  isSecret  Boolean  @default(false)
  label     String?
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@index([group])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  target    String?
  detail    Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model OperationTrace {
  id         String   @id @default(uuid())
  userId     String?
  category   String // recording | summary | socket | system
  action     String
  status     String   @default("ok") // ok | error
  durationMs Int?
  target     String?
  detail     Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([status])
  @@index([createdAt])
  @@index([userId])
}

model Draft {
  id          String   @id @default(uuid())
  userId      String
  title       String
  fullText    String?  @db.Text
  status      String   @default("recording") // recording | paused | stopped
  audioMode   String   @default("mic") // mic | tab
  recordingId String?
  startedAt   DateTime @default(now())
  lastSavedAt DateTime @default(now())
  orgId      String? // 录音时选用的组织上下文
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, lastSavedAt])
}

model Transcript {
  id          String   @id @default(uuid())
  userId      String
  title       String
  fullText    String?  @db.Text // store entire transcript here
  recordedAt  DateTime? // 会议录音开始时间（从草稿 startedAt 同步）
  recordingId String? // 完整录音归档 ID（uploads/{userId}/{recordingId}/recording.webm）
  orgId       String? // 从草稿带入的组织上下文
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user       User      @relation(fields: [userId], references: [id])
  summaries  Summary[]

  @@index([recordingId])
}

model SummarySkill {
  id           String   @id @default(uuid())
  userId       String?
  slug         String
  name         String
  rulesMd      String   @db.Text
  stepsMd      String?  @db.Text
  outputMd     String   @db.Text
  meta         Json?
  parentId     String?
  version      Int      @default(1)
  isPublic     Boolean  @default(false)
  reviewStatus String   @default("approved") // pending | approved | rejected
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user      User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    SummarySkill?     @relation("SkillFork", fields: [parentId], references: [id], onDelete: SetNull)
  forks     SummarySkill[]    @relation("SkillFork")
  templates SummaryTemplate[]

  @@index([userId])
  @@index([slug])
}

model SummaryTemplate {
  id                String   @id @default(uuid())
  userId            String?
  skillId           String
  name              String
  description       String?  @db.Text
  isDefault         Boolean  @default(false)
  isPublic          Boolean  @default(false)
  reviewStatus      String   @default("approved") // pending | approved | rejected
  legacySummaryType String? // meeting-notes | brief — 系统模板兼容旧 API
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  skill      SummarySkill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  user       User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  summaries  Summary[]

  @@index([userId])
  @@index([legacySummaryType])
}

model Summary {
  id              String   @id @default(uuid())
  userId          String
  transcriptId    String
  summaryType     String   @default("meeting-notes") // legacy 冗余字段
  templateId      String
  templateVersion Int      @default(1)
  orgId           String? // 生成纪要时选用的组织身份
  text            String   @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transcript Transcript      @relation(fields: [transcriptId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  template   SummaryTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)

  @@unique([transcriptId, templateId])
  @@index([transcriptId])
  @@index([templateId])
}
